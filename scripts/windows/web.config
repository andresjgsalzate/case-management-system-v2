<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS ARR (Application Request Routing) reverse proxy configuration.
  Requirements:
    - IIS with ARR module: https://www.iis.net/downloads/microsoft/application-request-routing
    - URL Rewrite module:  https://www.iis.net/downloads/microsoft/url-rewrite
  Place this file at the IIS site root (e.g., C:\inetpub\wwwroot\cms\web.config)
  or point the IIS site to C:\CMS\frontend and place it there.
-->
<configuration>
  <system.webServer>

    <!-- Enable proxy -->
    <proxy enabled="true" reverseRewriteHostInResponseHeaders="false" />

    <rewrite>
      <rules>

        <!-- ── SSE: disable response buffering ───────────────────── -->
        <rule name="CMS SSE" stopProcessing="true">
          <match url="^api/v1/notifications/stream" />
          <action type="Rewrite" url="http://127.0.0.1:8000/{R:0}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
          </serverVariables>
        </rule>

        <!-- ── API → FastAPI backend ─────────────────────────────── -->
        <rule name="CMS API" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:8000/api/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_REAL_IP" value="{REMOTE_ADDR}" />
          </serverVariables>
        </rule>

        <!-- ── Frontend → Next.js ────────────────────────────────── -->
        <rule name="CMS Frontend" stopProcessing="true">
          <match url="^(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3000/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_REAL_IP" value="{REMOTE_ADDR}" />
          </serverVariables>
        </rule>

      </rules>

      <!-- Rewrite response Location headers for redirects -->
      <outboundRules>
        <rule name="Rewrite Location Header">
          <match serverVariable="RESPONSE_Location" pattern="^http://127\.0\.0\.1:(8000|3000)/(.*)" />
          <action type="Rewrite" value="/{R:2}" />
        </rule>
      </outboundRules>
    </rewrite>

    <!-- Security headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Frame-Options"        value="SAMEORIGIN" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="Referrer-Policy"        value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>

    <!-- Increase upload limit to 25 MB -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="26214400" />
      </requestFiltering>
    </security>

    <!-- Static asset caching for Next.js _next/static -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
    </staticContent>

    <!-- Remove IIS version header -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>
