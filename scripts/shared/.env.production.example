# ============================================================
#  Case Management System — Production Environment Variables
#  Copy to .env.production and fill in all values
# ============================================================

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cms_user:CHANGE_ME@localhost:5432/cms_production

# ── Security ────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Application ─────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
ALLOWED_ORIGINS=https://yourdomain.com

# ── Redis (optional — for future caching/rate-limiting) ─────
REDIS_URL=redis://localhost:6379/0

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@yourdomain.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=CMS Notifications <notifications@yourdomain.com>

# ── File Uploads ─────────────────────────────────────────────
UPLOAD_DIR=/var/lib/cms/uploads
MAX_UPLOAD_SIZE_MB=20

# ── Frontend (Next.js) ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
PORT=3000
NODE_ENV=production
