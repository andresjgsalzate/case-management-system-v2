# ============================================================
# ARCHIVO DE EJEMPLO — Copia como .env y completa los valores
# NUNCA uses este archivo directamente en producción
# Para generar SECRET_KEY: openssl rand -hex 32
# ============================================================

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/case_management

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads  # Ruta relativa al directorio de trabajo; debe existir previamente

# Email (optional — notifications disabled if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
